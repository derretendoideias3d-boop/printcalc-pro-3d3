rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //
    // Collection: budgets
    // Document ID: {budgetId}
    // Fields:
    //   - uid: string (required)
    //   - clientName: string (required)
    //   - fileName: string (required)
    //   - results: map (required)
    //   - details: map (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['uid', 'clientName', 'fileName', 'results', 'details']) &&
             data.uid == request.auth.uid &&
             data.clientName is string && data.clientName.size() < 200 &&
             data.fileName is string && data.fileName.size() < 500;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /budgets/{budgetId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidBudget(request.resource.data);
      allow update: if isDocOwner() && isValidBudget(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
